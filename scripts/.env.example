# Copy this file to `.env` and fill in values. Never commit `.env`.

# --- RAG / Ollama (ArabicRAGChatbot) ---
LLM_MODEL=deepseek-v3.1:671b-cloud
EMBED_MODEL=bge-m3
# Chroma DB folder (omit this line or set a path — do NOT use PERSIST_DIR= empty)
# Default if unset: ./chroma_db next to rag_api.py
# PERSIST_DIR=chroma_db
OLLAMA_BASE_URL=http://localhost:11434
RETRIEVAL_STRATEGY=mmr

# --- Multi-provider LLM (tool routing) ---
# Set LLM_PROVIDER to "openai_compatible" to enable tool routing via DeepSeek / OpenAI API.
# Leave as "ollama" (default) to keep the existing local Ollama behaviour unchanged.
LLM_PROVIDER=ollama
# Required when LLM_PROVIDER=openai_compatible:
LLM_API_KEY=
LLM_API_BASE_URL=https://api.deepseek.com
# LLM_MODEL overrides the model name when LLM_PROVIDER=openai_compatible:
# LLM_MODEL=deepseek-chat

# --- Mock API / Tool calling ---
# JWT token for the mock university API (port 5001). The chatbot fetches a
# fresh token automatically if this is left blank, but setting it avoids the
# extra /auth/token request on every tool call.
# Obtain one by running: python mock_api_server.py  then POST /auth/token
MOCK_API_TOKEN=

# --- SQLite & uploads (optional overrides) ---
# RAG_DB_PATH=rag_admin.db
# RAG_UPLOADS_DIR=uploads

# --- Flask API (rag_api.py `if __name__ == '__main__'`) ---
RAG_API_HOST=0.0.0.0
RAG_API_PORT=5000

# --- React Admin Panel JWT Auth ---
# Change this to a long random string in production
JWT_SECRET_KEY=changeme-hebron-admin-secret

# --- Streamlit apps (app.py, pages/Admin_Panel.py) ---
RAG_API_URL=http://localhost:5000

# --- Telegram webhook ---
# Get token from @BotFather
TELEGRAM_BOT_TOKEN=
# Optional: Markdown, HTML, etc. Omit or leave empty to send plain text (recommended).
# TELEGRAM_PARSE_MODE=Markdown

# --- WhatsApp Cloud API webhook ---
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_GRAPH_API_VERSION=v17.0

# --- Facebook Messenger webhook ---
MESSENGER_PAGE_ACCESS_TOKEN=
MESSENGER_VERIFY_TOKEN=
MESSENGER_GRAPH_API_VERSION=v19.0

# --- Rate limiting (Redis-backed, LLM/RAG answers only) ---
# Set RATE_LIMIT_ENABLED=false to disable entirely (e.g. local dev without Redis).
# FAQ and manual override answers are always free and never consume quota.
RATE_LIMIT_ENABLED=true
# Set to "fakeredis" for local dev/demo with no Redis server needed (in-process).
# Set to a real URL when a Redis server is running: redis://localhost:6379/0
REDIS_URL=fakeredis
# Max weighted quota units per 60-second window per user (across all channels).
RATE_LIMIT_LLM_PER_MINUTE=10
# Max weighted quota units per UTC calendar day per user.
RATE_LIMIT_LLM_PER_DAY=100
# Cost of a short plain-text LLM answer (< RATE_LIMIT_LONG_TEXT_CHARS chars).
RATE_LIMIT_TEXT_COST=1
# Questions longer than this threshold cost RATE_LIMIT_LONG_TEXT_COST instead.
RATE_LIMIT_LONG_TEXT_CHARS=800
RATE_LIMIT_LONG_TEXT_COST=2
# Cost of an audio message that proceeds to transcription + LLM.
RATE_LIMIT_AUDIO_COST=3
# true = allow requests when Redis is down (chatbot keeps working, logs a warning).
# false = block requests when Redis is unavailable (stricter cost control).
RATE_LIMIT_FAIL_OPEN=true
